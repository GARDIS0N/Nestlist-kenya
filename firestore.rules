rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny-all for anything not explicitly matched
    match /{document=**} {
      allow read, write: if false;
    }

    // Profiles rules
    // - anyone signed in can read
    // - users can only create/update their own profile
    // - role cannot be changed after creation
    // - no deletes
    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId 
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
    }

    // Properties rules
    // - public read only where is_active == true
    // - landlords can always read their own
    // - only landlords can create (with landlord_id matching their own UID and is_active forced to false on creation)
    // - landlords can update their own listing's editable fields but can never set is_active themselves
    match /properties/{propertyId} {
      allow read: if (resource != null && resource.data.is_active == true)
                  || (request.auth != null && resource != null && resource.data.landlord_id == request.auth.uid);
      allow create: if request.auth != null 
                    && request.resource.data.landlord_id == request.auth.uid
                    && request.resource.data.is_active == false;
      allow update: if request.auth != null 
                    && resource.data.landlord_id == request.auth.uid
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['is_active', 'expires_at', 'landlord_id']));
    }

    // Listing Payments rules
    // - landlords can read only their own records
    // - landlords can create a record with status "pending"
    // - absolutely no client-side updates or deletes
    match /listing_payments/{paymentId} {
      allow read: if request.auth != null && resource.data.landlord_id == request.auth.uid;
      allow create: if request.auth != null 
                    && request.resource.data.landlord_id == request.auth.uid 
                    && request.resource.data.status == 'pending';
    }

    // Inquiries rules
    // - only the tenant_id or landlord_id involved can read
    // - only tenants can create, naming themselves as tenant_id
    // - either party can update the status field only
    match /inquiries/{inquiryId} {
      allow read: if request.auth != null && (resource.data.tenant_id == request.auth.uid || resource.data.landlord_id == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.tenant_id == request.auth.uid;
      allow update: if request.auth != null 
                    && (resource.data.tenant_id == request.auth.uid || resource.data.landlord_id == request.auth.uid)
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['property_id', 'tenant_id', 'landlord_id', 'message', 'created_at']));

      // Subcollection messages
      // - only the inquiry's tenant or landlord can read or create messages
      match /messages/{messageId} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/inquiries/$(inquiryId)).data.tenant_id == request.auth.uid || 
          get(/databases/$(database)/documents/inquiries/$(inquiryId)).data.landlord_id == request.auth.uid
        );
        allow create: if request.auth != null && (
          get(/databases/$(database)/documents/inquiries/$(inquiryId)).data.tenant_id == request.auth.uid || 
          get(/databases/$(database)/documents/inquiries/$(inquiryId)).data.landlord_id == request.auth.uid
        );
      }
    }

    // Saved Properties rules
    // - tenant can read/create/delete only their own, enforcing the composite ID pattern
    match /saved_properties/{compositeId} {
      allow read: if request.auth != null && resource.data.tenant_id == request.auth.uid;
      allow create: if request.auth != null 
                    && request.resource.data.tenant_id == request.auth.uid 
                    && compositeId == request.auth.uid + '_' + request.resource.data.property_id;
      allow delete: if request.auth != null && resource.data.tenant_id == request.auth.uid;
    }

    // Search Alerts rules
    // - tenant can read/create/update/delete only their own
    // - the last_sent field can never be modified by the client
    match /search_alerts/{alertId} {
      allow read, delete: if request.auth != null && resource.data.tenant_id == request.auth.uid;
      allow create: if request.auth != null 
                    && request.resource.data.tenant_id == request.auth.uid 
                    && !request.resource.data.keys().hasAny(['last_sent']);
      allow update: if request.auth != null && resource.data.tenant_id == request.auth.uid 
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['last_sent', 'tenant_id']));
    }

    // SMS Logs rules - fully blocked from client read/write
    match /sms_logs/{logId} {
      allow read, write: if false;
    }
  }
}
